# 2. ALGORITMOS ADAPTATIVOS

class KalmanFilter:
    """Filtro de Kalman"""
    def __init__(self, Q=1e-3, R=1e-2):
        self.Q = Q
        self.R = R
        self.x = 0
        self.P = 1
        self.name = "Kalman"
    
    def update(self, z):
        x_pred = self.x
        P_pred = self.P + self.Q
        K = P_pred / (P_pred + self.R)
        self.x = x_pred + K * (z - x_pred)
        self.P = (1 - K) * P_pred
        return self.x, abs(z - x_pred)
    
    def reset(self):
        self.x = 0
        self.P = 1


class RLSFilter:
    """RLS"""
    def __init__(self, order=10, delta=1.0, lam=0.98):
        self.order = order
        self.delta = delta
        self.lam = lam
        self.w = np.zeros(order)
        self.P = np.eye(order) / delta
        self.buffer = np.zeros(order)
        self.name = "RLS"
    
    def update(self, z):
        self.buffer = np.roll(self.buffer, 1)
        self.buffer[0] = z
        
        y_pred = np.dot(self.w, self.buffer)
        error = abs(z - y_pred)
        
        pi = np.dot(self.P, self.buffer)
        k = pi / (self.lam + np.dot(self.buffer, pi))
        self.w = self.w + k * (z - y_pred)
        self.P = (self.P - np.outer(k, pi)) / self.lam
        
        return y_pred, error
    
    def reset(self):
        self.w = np.zeros(self.order)
        self.P = np.eye(self.order) / self.delta
        self.buffer = np.zeros(self.order)

# 3. FUNÇÕES DE FEATURES

def shannon_entropy(signal):
    """Entropia de Shannon Normalizada"""
    hist, _ = np.histogram(signal, bins=50, density=True)
    hist = hist[hist > 0]
    return entropy(hist) / np.log(len(hist)) if len(hist) > 1 else 0


def extract_multiple_features(window_data):
    """Extrai MÚLTIPLAS features por janela"""
    features = {}
    features['entropy'] = shannon_entropy(window_data.flatten())
    features['energy'] = np.mean(window_data**2)
    features['variance'] = np.var(window_data)
    features['mean_abs'] = np.mean(np.abs(window_data))
    return features


def extract_summary_data(summary_path):
    """Extrai crises do arquivo summary"""
    seizures = []
    try:
        with open(summary_path, 'r', encoding='utf-8') as f:
            content = f.read()
    except:
        return pd.DataFrame()

    lines = content.split('\n')
    current_file = None
    
    for i, line in enumerate(lines):
        if 'File Name:' in line:
            current_file = line.split('File Name:')[1].strip().split()[0]
        
        if 'Seizure' in line and 'Start Time:' in line:
            try:
                start = int(re.search(r'Start Time: (\d+)', line).group(1))
                for j in range(i+1, min(i+5, len(lines))):
                    if 'End Time:' in lines[j]:
                        end = int(re.search(r'End Time: (\d+)', lines[j]).group(1))
                        seizures.append({'file': current_file, 'start': start, 'end': end})
                        break
            except:
                continue
    
    return pd.DataFrame(seizures)


def load_edf_file(edf_path, seizure_info):
    """Carrega EDF e extrai múltiplas features"""
    try:
        raw = mne.io.read_raw_edf(str(edf_path), preload=True, verbose=False)
        sfreq = raw.info['sfreq']
        
        eeg_channels = [ch for ch in raw.ch_names 
                       if (ch.startswith(('FP', 'F', 'T', 'C', 'P', 'O')) 
                           and '-' in ch and 'EKG' not in ch)]
        
        if not eeg_channels:
            return pd.DataFrame()
        
        raw.pick_channels(eeg_channels[:1])
        
        samples_per_window = int(sfreq * WINDOW_SEC)
        hop = int(samples_per_window * (1 - OVERLAP))
        n_windows = (raw.n_times - samples_per_window) // hop + 1
        
        data = []
        file_name = edf_path.name
        file_seizures = seizure_info[seizure_info['file'] == file_name]
        
        for i in range(n_windows):
            start_sample = i * hop
            t0 = start_sample / sfreq
            t1 = t0 + WINDOW_SEC
            
            window_data = raw.get_data(start=start_sample, stop=start_sample + samples_per_window)
            features = extract_multiple_features(window_data)
            
            label = 0
            pre_ictal = 0
            
            for _, sz in file_seizures.iterrows():
                if max(t0, sz['start']) < min(t1, sz['end']):
                    label = 1
                
                pre_ictal_start = sz['start'] - PREDICTION_HORIZON_SEC
                if pre_ictal_start <= t0 < sz['start']:
                    pre_ictal = 1
            
            data.append({
                'file': file_name,
                't0': t0,
                't1': t1,
                'entropy': features['entropy'],
                'energy': features['energy'],
                'variance': features['variance'],
                'mean_abs': features['mean_abs'],
                'label': label,
                'pre_ictal': pre_ictal
            })
        
        return pd.DataFrame(data)
    
    except Exception as e:
        return pd.DataFrame()

