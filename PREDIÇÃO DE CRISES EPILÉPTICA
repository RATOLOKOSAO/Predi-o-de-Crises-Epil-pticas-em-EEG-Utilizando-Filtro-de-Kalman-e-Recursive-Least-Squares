    'Kalman': {},
    'RLS': {}
}

# DataFrame para armazenar matrizes de confusão
confusion_matrices_list = []

for patient_id in tqdm(patients_loaded, desc="Analisando pacientes"):
    df_patient = df[df['patient'] == patient_id].copy()
    
    # Verifica se há crises
    if df_patient['label'].sum() == 0:
        continue
    
    # Testa Kalman e RLS
    for algo_class in [KalmanFilter, RLSFilter]:
        algo = algo_class() if algo_class == KalmanFilter else RLSFilter(order=RLS_ORDER, lam=RLS_LAMBDA)
        
        # Aplica algoritmo em todos os arquivos do paciente
        patient_data_processed = []
        
        for file_name in df_patient['file'].unique():
            df_file = df_patient[df_patient['file'] == file_name].copy()
            
            algo.reset()
            errors = []
            for feat_val in df_file['feature_combined'].values:
                _, error = algo.update(feat_val)
                errors.append(error)
            
            df_file[f'error'] = errors
            df_file[f'error_smooth'] = pd.Series(errors).rolling(
                window=SMOOTHING_WINDOW, min_periods=1
            ).mean().values
            
            patient_data_processed.append(df_file)
        
        df_patient_processed = pd.concat(patient_data_processed, ignore_index=True)
        
        # Calcula limiar baseado em região interictal pura
        baseline = df_patient_processed[(df_patient_processed['label'] == 0) & 
                                       (df_patient_processed['pre_ictal'] == 0)]
        
        if len(baseline) < 10:
            continue
        
        mean_error = baseline['error_smooth'].mean()
        std_error = baseline['error_smooth'].std()
        threshold = mean_error + SIGMA_OPTIMAL * std_error
        
        # Aplica detecção
        df_patient_processed['alert_raw'] = (df_patient_processed['error_smooth'] > threshold).astype(int)
        
        # Alerta sustentado
        df_patient_processed['alert'] = df_patient_processed.groupby('file')['alert_raw'].rolling(
            window=10, min_periods=10
        ).sum().reset_index(level=0, drop=True)
        df_patient_processed['alert'] = (df_patient_processed['alert'] == 10).astype(int)
        
        # MATRIZ DE CONFUSÃO DO PACIENTE janelas não-ictais
        df_eval = df_patient_processed[df_patient_processed['label'] == 0]
        
        if len(df_eval) > 0:
            y_true = df_eval['pre_ictal'].values
            y_pred = df_eval['alert'].values
            
            cm = confusion_matrix(y_true, y_pred, labels=[0, 1])
            TN, FP, FN, TP = cm[0, 0], cm[0, 1], cm[1, 0], cm[1, 1]
            
            # Métricas
            accuracy = (TP + TN) / (TP + TN + FP + FN + 1e-10)
            precision = TP / (TP + FP + 1e-10)
            recall = TP / (TP + FN + 1e-10)
            specificity = TN / (TN + FP + 1e-10)
            f1 = 2 * precision * recall / (precision + recall + 1e-10)
            
            # SPR (por evento)
            num_seizures = df_patient_processed[df_patient_processed['label'] == 1]['file'].nunique()
            seizures_detected = 0
            
            for file_name in df_patient_processed[df_patient_processed['label'] == 1]['file'].unique():
                df_file = df_patient_processed[df_patient_processed['file'] == file_name]
                pre_ictal_alerts = df_file[(df_file['pre_ictal'] == 1) & (df_file['alert'] == 1)]
                if not pre_ictal_alerts.empty:
                    seizures_detected += 1
            
            spr = seizures_detected / num_seizures if num_seizures > 0 else 0
            
            # Armazena resultados
            confusion_matrices_list.append({
                'Paciente': patient_id,
                'Algoritmo': algo.name,
                'TN': TN,
                'FP': FP,
                'FN': FN,
                'TP': TP,
                'Acurácia': accuracy,
                'Precision': precision,
                'Recall': recall,
                'Specificity': specificity,
                'F1-Score': f1,
                'SPR': spr,
                'Num_Crises': num_seizures,
                'Crises_Detectadas': seizures_detected
            })

# Converte para DataFrame
df_confusion = pd.DataFrame(confusion_matrices_list)

